{
  "name": "haotang-couple-play",
  "version": "0.1.0",
  "private": true,
  "description": "豪豪和小糖豆的游戏网站 - 情侣实时小游戏 MVP",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "next dev -p 3000",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "next build && tsc -p server/tsconfig.json --noEmit",
    "start:web": "next start -p 3000",
    "start:server": "tsx server/src/index.ts",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "lint": "next lint"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "tsx": "^4.16.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3"
  }
}
